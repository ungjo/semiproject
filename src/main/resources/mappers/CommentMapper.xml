<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<mapper namespace="com.example.semiproject.mapper.CommentMapper">
	<!--
		[댓글 목록] 특정 게시물의 댓글 목록 조회
		JOIN MEMBER - 댓글 작성자 아이디를 가져오기 위해 MEMBER테이블과 연결
	-->
	<select id="selectByBoardId" resultType="com.example.semiproject.dto.CommentDTO">	<!--CommentMapper와 이름 같게 조회되는 행 하나하나는 CommentDTO타입으로 반환받겠다는 뜻-->
		SELECT c.COMMENT_ID,
				c.COMMENT_CONTENT,
				DATE_FORMAT(c.COMMENT_DATE, "%Y-%m-%d %H:%i:%s") AS COMMENT_DATE,
				c.BOARD_ID,
				c.MEMBER_ID,
				m.MEMBER_LOGINID
		FROM COMMENT c
			JOIN MEMBER m ON c.MEMBER_ID = m.MEMBER_ID
		WHERE c.BOARD_ID = #{boardId}
		ORDER BY c.COMMENT_ID ASC
	</select>
	
	<!--
		[댓글 등록]
		COMMENT_DATE는 DEFAULT NOW() 이므로 INSERT에서 생략
		useGeneratedKeys="true", keyProperty="commentId"
		=> DB가 자동 생성한 COMMENT_ID 값을 commentDTO.commentId 필드에 저장 -> 등록 후 JSON 응답에 새 commentId를 포함시키기 위해 필요
	-->
	<insert id="insertComment" parameterType="com.example.semiproject.dto.CommentDTO" useGeneratedKeys="true" keyProperty="commentId">
		INSERT INTO COMMENT(COMMENT_CONTENT, BOARD_ID, MEMBER_ID)
		VALUES(#{commentContent}, #{boardId}, #{memberId})
	</insert>
	
	<!--
		[댓글 삭제] 댓글 번호로 특정 댓글 1개 삭제
	-->
	<delete id="deleteComment">
		DELETE FROM COMMENT
			WHERE COMMENT_ID = #{commentId}
	</delete>
	
</mapper>